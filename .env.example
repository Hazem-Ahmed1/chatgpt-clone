# ══════════════════════════════════════════════════════════════
#  ChatGPT Clone — Environment Variables
#  Copy this file to .env and fill in your API keys.
#  Get keys from the links below — all free-tier options exist.
# ══════════════════════════════════════════════════════════════

# ── Required: at least one of these three ────────────────────

# Groq  (FREE, ultra-fast) → https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Google Gemini  (FREE tier) → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# DeepSeek  (very cheap) → https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# ── Optional: voice transcription ────────────────────────────
# Hugging Face token for Whisper STT
# (falls back to Groq Whisper if not set) → https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# ── Server ───────────────────────────────────────────────────
PORT=3000
